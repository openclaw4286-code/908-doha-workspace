{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "908 Doha Design System",
    "version": "0.9.0",
    "description": "Platform-neutral design tokens. Consume via build tools (Style Dictionary, Tokens Studio) or read directly."
  },

  "color": {
    "primitive": {
      "grey": {
        "50":  { "$value": "#FAF9F6", "$type": "color", "$description": "Warm sand ramp — subtle +R/-B bias over pure neutral; luminance preserved so AA holds." },
        "100": { "$value": "#F2F0EB", "$type": "color" },
        "200": { "$value": "#E5E2DA", "$type": "color" },
        "300": { "$value": "#CECABE", "$type": "color" },
        "400": { "$value": "#9A9588", "$type": "color" },
        "500": { "$value": "#747067", "$type": "color" },
        "600": { "$value": "#53504A", "$type": "color" },
        "700": { "$value": "#34312D", "$type": "color" },
        "800": { "$value": "#1A1815", "$type": "color" },
        "900": { "$value": "#0A0907", "$type": "color", "$description": "Warm near-black — never pure #000. Shadow tint base." }
      },
      "primary": {
        "50":  { "$value": "#E8F1FF", "$type": "color" },
        "100": { "$value": "#CCE0FF", "$type": "color" },
        "200": { "$value": "#99C1FF", "$type": "color" },
        "300": { "$value": "#66A1FF", "$type": "color" },
        "400": { "$value": "#3382FF", "$type": "color" },
        "500": { "$value": "#0064FF", "$type": "color", "$description": "908 Blue — brand core" },
        "600": { "$value": "#0051CC", "$type": "color" },
        "700": { "$value": "#003D99", "$type": "color" },
        "800": { "$value": "#002966", "$type": "color" },
        "900": { "$value": "#001633", "$type": "color" }
