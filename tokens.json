  "font": {
    "family": {
      "sans":   { "$value": "\"Pretendard Variable\", Pretendard, -apple-system, \"SF Pro Text\", \"Helvetica Neue\", \"Noto Kufi Arabic\", system-ui, sans-serif", "$type": "fontFamily" },
      "serif":  { "$value": "\"Fraunces\", \"Times New Roman\", Georgia, serif", "$type": "fontFamily" },
      "mono":   { "$value": "\"JetBrains Mono\", \"SF Mono\", Menlo, Consolas, monospace", "$type": "fontFamily" },
      "arabic": { "$value": "\"Noto Kufi Arabic\", \"Pretendard Variable\", sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light":    { "$value": 300, "$type": "fontWeight" },
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "role": {
      "display":  { "size": "40px", "lineHeight": "48px", "letterSpacing": "-0.02em",  "weight": 700 },
      "title1":   { "size": "32px", "lineHeight": "40px", "letterSpacing": "-0.015em", "weight": 700 },
      "title2":   { "size": "26px", "lineHeight": "34px", "letterSpacing": "-0.012em", "weight": 600 },
      "title3":   { "size": "22px", "lineHeight": "30px", "letterSpacing": "-0.01em",  "weight": 600 },
      "heading1": { "size": "18px", "lineHeight": "26px", "letterSpacing": "-0.006em", "weight": 600 },
      "heading2": { "size": "16px", "lineHeight": "24px", "letterSpacing": "-0.004em", "weight": 600 },
      "body1":    { "size": "16px", "lineHeight": "26px", "letterSpacing": "-0.003em", "weight": 400 },
      "body2":    { "size": "14px", "lineHeight": "22px", "letterSpacing": "-0.002em", "weight": 400 },
      "label":    { "size": "13px", "lineHeight": "18px", "letterSpacing": "0",        "weight": 500 },
      "caption":  { "size": "12px", "lineHeight": "16px", "letterSpacing": "0",        "weight": 400 }
    }
  },

  "spacing": {
    "0":  { "$value": "0",    "$type": "dimension" },
    "1":  { "$value": "2px",  "$type": "dimension" },
    "2":  { "$value": "4px",  "$type": "dimension" },
    "3":  { "$value": "8px",  "$type": "dimension" },
    "4":  { "$value": "12px", "$type": "dimension" },
    "5":  { "$value": "16px", "$type": "dimension" },
    "6":  { "$value": "20px", "$type": "dimension" },
    "7":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "9":  { "$value": "40px", "$type": "dimension" },
    "10": { "$value": "48px", "$type": "dimension" },
    "11": { "$value": "64px", "$type": "dimension" },
    "12": { "$value": "80px", "$type": "dimension" }
  },

  "radius": {
    "xs":   { "$value": "4px",    "$type": "dimension" },
    "sm":   { "$value": "8px",    "$type": "dimension" },
    "md":   { "$value": "12px",   "$type": "dimension" },
    "lg":   { "$value": "16px",   "$type": "dimension" },
    "xl":   { "$value": "20px",   "$type": "dimension" },
    "2xl":  { "$value": "28px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "elevation": {
    "0": { "$value": "none" },
    "1": { "$value": "0 1px 2px rgba(26, 24, 21, 0.04), 0 1px 1px rgba(26, 24, 21, 0.03)" },
    "2": { "$value": "0 2px 6px rgba(26, 24, 21, 0.06), 0 1px 2px rgba(26, 24, 21, 0.04)" },
    "3": { "$value": "0 8px 20px rgba(26, 24, 21, 0.08), 0 2px 6px rgba(26, 24, 21, 0.05)" },
    "4": { "$value": "0 18px 40px rgba(26, 24, 21, 0.12), 0 4px 12px rgba(26, 24, 21, 0.06)" }
  },

  "motion": {
    "duration": {
      "fast":   { "$value": "160ms", "$type": "duration" },
      "normal": { "$value": "280ms", "$type": "duration" },
      "slow":   { "$value": "480ms", "$type": "duration" },
      "xslow":  { "$value": "720ms", "$type": "duration" }
    },
    "easing": {
      "out":      { "$value": "cubic-bezier(0.22, 1, 0.36, 1)" },
      "in-out":   { "$value": "cubic-bezier(0.76, 0, 0.24, 1)" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)" },
      "soft":     { "$value": "cubic-bezier(0.32, 0.72, 0, 1)", "$description": "Signature 908 easing — use for every state change by default." },
      "emphasis": { "$value": "cubic-bezier(0.2, 0, 0, 1)" }
    }
  }
}
