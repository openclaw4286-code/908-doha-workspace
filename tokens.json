      "orange": {
        "50":  { "$value": "#FBEFE3", "$type": "color" },
        "100": { "$value": "#F6DBBC", "$type": "color" },
        "200": { "$value": "#EFBB85", "$type": "color" },
        "300": { "$value": "#E59A52", "$type": "color" },
        "400": { "$value": "#D57B29", "$type": "color" },
        "500": { "$value": "#B5610F", "$type": "color" },
        "600": { "$value": "#904C0A", "$type": "color" },
        "700": { "$value": "#6B3807", "$type": "color" },
        "800": { "$value": "#4A2604", "$type": "color" },
        "900": { "$value": "#2B1602", "$type": "color" }
      },
      "yellow": {
        "50":  { "$value": "#FBF3D6", "$type": "color" },
        "100": { "$value": "#F6E6A7", "$type": "color" },
        "200": { "$value": "#EDD468", "$type": "color" },
        "300": { "$value": "#DCBB2D", "$type": "color" },
        "400": { "$value": "#BE9D12", "$type": "color" },
        "500": { "$value": "#95790A", "$type": "color" },
        "600": { "$value": "#735C06", "$type": "color" },
        "700": { "$value": "#524204", "$type": "color" },
        "800": { "$value": "#332902", "$type": "color" },
        "900": { "$value": "#1B1601", "$type": "color" }
      },
      "teal": {
        "50":  { "$value": "#E4F4F4", "$type": "color" },
        "100": { "$value": "#BFE4E4", "$type": "color" },
        "200": { "$value": "#82C9C9", "$type": "color" },
        "300": { "$value": "#48ACAC", "$type": "color" },
        "400": { "$value": "#1E8C8C", "$type": "color" },
        "500": { "$value": "#0A6E6E", "$type": "color" },
        "600": { "$value": "#075757", "$type": "color" },
        "700": { "$value": "#054040", "$type": "color" },
        "800": { "$value": "#042C2C", "$type": "color" },
        "900": { "$value": "#021818", "$type": "color" }
      },
      "purple": {
        "50":  { "$value": "#EFEAF5", "$type": "color" },
        "100": { "$value": "#DACEE7", "$type": "color" },
        "200": { "$value": "#B49ECF", "$type": "color" },
        "300": { "$value": "#8D6FB3", "$type": "color" },
        "400": { "$value": "#6B4B95", "$type": "color" },
        "500": { "$value": "#4F3478", "$type": "color" },
        "600": { "$value": "#3E2960", "$type": "color" },
        "700": { "$value": "#2E1E48", "$type": "color" },
        "800": { "$value": "#1E1330", "$type": "color" },
        "900": { "$value": "#0F091B", "$type": "color" }
      }
    },
    "semantic": {
      "light": {
        "background":         { "$value": "{color.primitive.grey.50}", "$type": "color" },
        "surface":            { "$value": "#FFFFFF", "$type": "color" },
        "surface-layered":    { "$value": "{color.primitive.grey.50}", "$type": "color" },
        "surface-sunken":     { "$value": "{color.primitive.grey.100}", "$type": "color" },
        "text-primary":       { "$value": "{color.primitive.grey.900}", "$type": "color" },
        "text-secondary":     { "$value": "{color.primitive.grey.600}", "$type": "color" },
        "text-tertiary":      { "$value": "{color.primitive.grey.400}", "$type": "color" },
        "text-inverted":      { "$value": "#FFFFFF", "$type": "color" },
        "text-brand":         { "$value": "{color.primitive.primary.600}", "$type": "color" },
        "border-subtle":      { "$value": "{color.primitive.grey.100}", "$type": "color" },
        "border-default":     { "$value": "{color.primitive.grey.200}", "$type": "color" },
        "border-strong":      { "$value": "{color.primitive.grey.300}", "$type": "color" },
        "border-focus":       { "$value": "{color.primitive.primary.500}", "$type": "color" },
        "accent-brand":       { "$value": "{color.primitive.primary.500}", "$type": "color" },
        "accent-brand-hover": { "$value": "{color.primitive.primary.600}", "$type": "color" },
        "accent-brand-press": { "$value": "{color.primitive.primary.700}", "$type": "color" },
        "accent-brand-soft":  { "$value": "{color.primitive.primary.50}", "$type": "color" },
        "state-positive":     { "$value": "{color.primitive.green.500}", "$type": "color" },
        "state-negative":     { "$value": "{color.primitive.red.500}", "$type": "color" },
        "state-warning":      { "$value": "{color.primitive.orange.500}", "$type": "color" },
        "state-info":         { "$value": "{color.primitive.teal.500}", "$type": "color" }
      },
      "dark": {
        "background":         { "$value": "#0A0A09", "$type": "color" },
        "surface":            { "$value": "#141413", "$type": "color" },
        "surface-layered":    { "$value": "#1C1C1A", "$type": "color" },
        "surface-sunken":     { "$value": "#050504", "$type": "color" },
        "text-primary":       { "$value": "#F7F6F3", "$type": "color" },
        "text-secondary":     { "$value": "#A7A49C", "$type": "color" },
        "text-tertiary":      { "$value": "#6E6B63", "$type": "color" },
        "text-inverted":      { "$value": "{color.primitive.grey.900}", "$type": "color" },
        "text-brand":         { "$value": "#FFFFFF", "$type": "color" },
        "border-subtle":      { "$value": "rgba(242, 240, 235, 0.06)", "$type": "color" },
        "border-default":     { "$value": "rgba(242, 240, 235, 0.10)", "$type": "color" },
        "border-strong":      { "$value": "rgba(242, 240, 235, 0.18)", "$type": "color" },
        "border-focus":       { "$value": "{color.primitive.primary.300}", "$type": "color" },
        "accent-brand":       { "$value": "{color.primitive.primary.400}", "$type": "color" },
        "state-positive":     { "$value": "{color.primitive.green.400}", "$type": "color" },
        "state-negative":     { "$value": "{color.primitive.red.400}", "$type": "color" },
        "state-warning":      { "$value": "{color.primitive.orange.400}", "$type": "color" },
        "state-info":         { "$value": "{color.primitive.teal.400}", "$type": "color" }
      }
    }
