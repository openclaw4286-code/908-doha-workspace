      "red": {
        "50":  { "$value": "#FDECEA", "$type": "color" },
        "100": { "$value": "#FBD3CF", "$type": "color" },
        "200": { "$value": "#F6A7A0", "$type": "color" },
        "300": { "$value": "#EE7A71", "$type": "color" },
        "400": { "$value": "#E15347", "$type": "color" },
        "500": { "$value": "#D23826", "$type": "color" },
        "600": { "$value": "#AC2B1C", "$type": "color" },
        "700": { "$value": "#851F14", "$type": "color" },
        "800": { "$value": "#5E160E", "$type": "color" },
        "900": { "$value": "#380B07", "$type": "color" }
      },
      "green": {
        "50":  { "$value": "#E9F5EC", "$type": "color" },
        "100": { "$value": "#CEE8D4", "$type": "color" },
        "200": { "$value": "#9ED2AB", "$type": "color" },
        "300": { "$value": "#6BB982", "$type": "color" },
        "400": { "$value": "#3E9F5E", "$type": "color" },
        "500": { "$value": "#1E8443", "$type": "color" },
        "600": { "$value": "#166934", "$type": "color" },
        "700": { "$value": "#0F4E26", "$type": "color" },
        "800": { "$value": "#09361A", "$type": "color" },
        "900": { "$value": "#04200F", "$type": "color" }
